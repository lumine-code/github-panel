{
  "name": "github-panel",
  "author": "lumine-code",
  "main": "./lib/index",
  "version": "2.0.0",
  "description": "A GitHub integration panel for Lumine.",
  "repository": "https://github.com/lumine-code/github-panel",
  "bugs": {
    "url": "https://github.com/lumine-code/github-panel/issues"
  },
  "homepage": "https://github.com/lumine-code/github-panel#readme",
  "license": "MIT",
  "engines": {
    "atom": "*",
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test spec/*.test.js",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "classnames": "2.5.1",
    "dayjs": "^1.11.19",
    "dompurify": "3.3.1",
    "keytar": "7.9.0",
    "marked": "15.0.7",
    "node-emoji": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-relay": "20.1.1",
    "react-select": "^5.10.2",
    "react-tabs": "6.1.0",
    "relay-runtime": "20.1.1",
    "what-the-diff": "0.6.0",
    "yubikiri": "2.0.0"
  },
  "consumedServices": {
    "status-bar": {
      "versions": {
        "^1.0.0": "consumeStatusBar"
      }
    }
  },
  "configSchema": {
    "openGitHubTabOnStart": {
      "order": 1,
      "type": "boolean",
      "default": false,
      "description": "Automatically open the GitHub tab when the editor starts"
    },
    "debug": {
      "order": 2,
      "type": "boolean",
      "default": false,
      "description": "Log additional debug information to the console, including caught errors and diagnostics"
    }
  },
  "deserializers": {
    "IssueishDetailItem": "createIssueishPaneItemStub",
    "IssueishPaneItem": "createIssueishPaneItemStub",
    "GithubDockItem": "createDockItemStub",
    "ReviewsStub": "createReviewsStub"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.9.5"
  }
}
